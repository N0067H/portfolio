classDiagram
    direction LR

    class MonitoredApi {
        <<API 등록 정보>>
        + apiId : String PK
        + url : String
        + interval_sec : int
        + timeout_ms : int
        + threshold : int
        + consecutiveFailures : int
        + lastAlertAt : String
    }
    class CheckHistory {
        <<체크 이력>>
        + apiId : String FK
        + checkedAt : String PK
        + statusCode : int
        + responseTimeMs : int
        + isSuccess : boolean
    }

    MonitoredApi "1" --> "0..*" CheckHistory
